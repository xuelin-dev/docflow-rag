# ── DocFlow RAG Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM & Embeddings ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ── Database (PostgreSQL) ──────────────────────────────────────────
POSTGRES_DB=docflow
POSTGRES_USER=docflow
POSTGRES_PASSWORD=docflow
DATABASE_URL=postgresql+asyncpg://docflow:docflow@localhost:5432/docflow

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SEMANTIC_CACHE_TTL=3600
SEMANTIC_CACHE_THRESHOLD=0.92

# ── Milvus ─────────────────────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=docflow_chunks

# ── MinIO (Milvus object storage) ─────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ── Application ────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info
API_HOST=0.0.0.0
API_PORT=8000

# ── Chunking ───────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNKING_STRATEGY=semantic

# ── Retrieval ──────────────────────────────────────────────────────
DEFAULT_TOP_K=5
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Observability (Arize Phoenix) ─────────────────────────────────
PHOENIX_ENABLED=false
PHOENIX_ENDPOINT=http://localhost:6006

# ── Frontend ───────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
